# Credenciales del usuario admin (se crea automáticamente al iniciar)
ADMIN_USERNAME=admin@admin.com
ADMIN_PASSWORD=admin123

# Puerto local para PostgreSQL.
# Dentro de Docker se sigue usando postgres:5432; este valor solo afecta al host.
POSTGRES_HOST_PORT=5433

# Puertos locales de la app.
# Dentro de Docker el backend sigue escuchando en 8080 y el frontend en 80.
BACKEND_HOST_PORT=18080
FRONTEND_HOST_PORT=3000
